PORT=4000
DATABASE_URL="postgresql://user:password@localhost:5432/paragonsplit"
JWT_SECRET="replace-with-strong-secret"

# Google Vision OCR — wpisz TYLKO lokalnie w backend/.env (nigdy na GitHubie)
GOOGLE_CLOUD_VISION_API_KEY="your-google-vision-api-key"

# Twarde limity OCR (domyślnie: 500 łącznie, max 10 na 10 minut)
OCR_MAX_TOTAL=500
OCR_MAX_PER_WINDOW=10
OCR_WINDOW_MINUTES=10
