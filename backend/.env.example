PORT=4000
NODE_ENV=development

# Baza — wpisz TYLKO lokalnie w backend/.env (NIGDY na GitHubie)
DATABASE_URL="postgresql://user:password@localhost:5432/paragonsplit"

# Min. 32 znaki na produkcji — wygeneruj losowy ciąg, np. openssl rand -base64 48
JWT_SECRET="replace-with-long-random-secret-at-least-32-chars"

# Google Vision OCR — wpisz TYLKO lokalnie w backend/.env (NIGDY na GitHubie)
GOOGLE_CLOUD_VISION_API_KEY="your-google-vision-api-key"

# Produkcja: dozwolone originy frontendu, po przecinku
# CORS_ORIGINS="https://twoja-domena.pl"
# Dev: zostaw puste — CORS otwarty lokalnie

# Twarde limity OCR (domyślnie: 500 łącznie, max 10 na 10 minut)
OCR_MAX_TOTAL=500
OCR_MAX_PER_WINDOW=10
OCR_WINDOW_MINUTES=10
